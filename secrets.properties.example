# Copy to secrets.properties (gitignored) and fill in. Do NOT commit secrets.properties.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Generate once via the Spotify auth flow (see README "Spotify refresh token").
SPOTIFY_REFRESH_TOKEN=

# Free token from https://www.football-data.org/client/register
# Blank -> FIFA tile shows a labeled static fallback (no crash).
FOOTBALL_DATA_TOKEN=

# Google Calendar -> Settings -> your calendar -> "Secret address in iCal format"
# Blank -> Calendar tile shows a tidy empty state (no crash).
CALENDAR_ICAL_URL=
